# =============================================================================
# Training Tracker credentials
# Copy this file to ".env" and fill in your values. ".env" is gitignored.
# =============================================================================

# --- Strava (covers both outdoor rides AND Zwift, since Zwift auto-uploads to
#     Strava with power data) -------------------------------------------------
# Create an app at https://www.strava.com/settings/api to get these two values.
# Then run:  python scripts/auth_strava.py   to authorize and capture a refresh
# token (the helper writes STRAVA_REFRESH_TOKEN back into this file for you).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Oura -------------------------------------------------------------------
# Create a Personal Access Token at https://cloud.ouraring.com/personal-access-tokens
OURA_ACCESS_TOKEN=

# --- Optional: auto-written coach narrative in the daily briefing ------------
# If set, the scheduled job adds a natural-language recommendation written by
# Claude. Leave blank to use the built-in rule-based recommendation instead.
# (Interactive deep-dive reasoning is always available via the /training-brief
#  slash command in Claude Code, which uses your subscription — no key needed.)
ANTHROPIC_API_KEY=
